[run]
# Cover only the real production code — skip scripts, ad-hoc experiments,
# tests, third-party, and the dead metric_routes.py module.
source = app, metric_engine, tasks
branch = false

[report]
# Exclude common defensive lines from the count.
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    \.\.\.
show_missing = false
skip_covered = false
precision = 1

[html]
directory = .coverage_html
