<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}dTOF Benchmarking{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">

    <style>
        body {
            padding-top: 56px;
            /* Adjust body padding to account for fixed navbar */
        }

        .navbar-brand .logo {
            width: 24px;
            height: 24px;
            margin-right: 8px;
            vertical-align: text-bottom;
        }

        .table-responsive {
            overflow-x: auto;
        }

        .chart-container {
            position: relative;
            height: 250px;
            width: 100%;
        }

        .hist-chart-container {
            position: relative;
            height: 120px;
            width: 100%;
            cursor: pointer;
            /* Add pointer cursor to indicate it's clickable */
        }

        .json-display {
            max-height: 150px;
            overflow: auto;
            white-space: pre-wrap;
            word-break: break-all;
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: .25rem;
            padding: .5rem .75rem;
            font-family: monospace;
            font-size: 0.875em;
        }

        .page-container {
            width: 100%;
            overflow-x: auto;
        }

        .content-wrapper {
            min-width: 1200px;
            /* Adjust as needed */
        }

        #chart-modal .modal-dialog {
            max-width: 90%;
        }

        #modal-chart-container {
            height: 70vh;
        }

        /* Footer Styling */
        footer {
            margin-top: 3rem;
            padding: 1.5rem 0;
            border-top: 1px solid #dee2e6;
            background-color: #f8f9fa;
            color: #6c757d;
            font-size: 0.9rem;
        }

        .version-info {
            font-weight: 500;
            color: #495057;
        }

        /* Gallery Footer Styles */
        .gallery-footer {
            overflow-x: auto;
            white-space: nowrap;
            padding: 10px;
            background: #f1f1f1;
            border-top: 1px solid #ccc;
            display: flex;
            gap: 10px;
        }

        .gallery-item {
            display: inline-block;
            width: 80px;
            height: 60px;
            background: #fff;
            border: 2px solid transparent;
            cursor: pointer;
            opacity: 0.6;
            transition: all 0.2s;
            text-align: center;
            font-size: 0.7rem;
            overflow: hidden;
            position: relative;
            flex-shrink: 0;
            border-radius: 4px;
        }

        .gallery-item:hover {
            opacity: 1;
        }

        .gallery-item.active {
            border-color: #0d6efd;
            opacity: 1;
            box-shadow: 0 0 5px rgba(13, 110, 253, 0.5);
        }

        .gallery-thumb-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .gallery-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #e9ecef;
            color: #6c757d;
            font-weight: bold;
            padding: 2px;
            word-wrap: break-word;
            white-space: normal;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ url_for('index') }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                    class="bi bi-bar-chart-line-fill logo" viewBox="0 0 16 16">
                    <path
                        d="M11 2a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v12h.5a.5.5 0 0 1 0 1H.5a.5.5 0 0 1 0-1H1v-3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3h1V7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7h1V2z" />
                </svg>
                dTOF Benchmarking
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ url_for('index') }}">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ url_for('metrics_view') }}">Metrics</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ url_for('docs') }}" target="_blank">Docs</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ url_for('settings_page') }}">Settings</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container-fluid mt-4"> <!-- Use container-fluid for more width -->
        <!-- Flash Messages -->
        {% with messages = get_flashed_messages(with_categories=true) %}
        {% if messages %}
        {% for category, message in messages %}
        <div class="alert alert-{{ category }} alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        {% endfor %}
        {% endif %}
        {% endwith %}

        {% block content %}{% endblock %}
    </main>

    <footer class="text-center">
        <div class="container">
            <p class="mb-0">dTOF Benchmarking &copy; {{ now.year if now else '2026' }} | <span class="version-info">v{{
                    version }}</span></p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1"></script>
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>

    <script>
        class GalleryModalManager {
            constructor(modalId, footerContainerId, onSelectCallback) {
                this.modalId = modalId;
                this.modalElement = document.getElementById(modalId);
                this.footerContainer = document.getElementById(footerContainerId);
                this.onSelect = onSelectCallback;
                this.items = [];
                this.currentIndex = -1;
                this._boundKeyHandler = this.handleKeydown.bind(this);

                if (this.modalElement) {
                    this.modalElement.addEventListener('shown.bs.modal', () => {
                        window.addEventListener('keydown', this._boundKeyHandler);
                    });
                    this.modalElement.addEventListener('hidden.bs.modal', () => {
                        window.removeEventListener('keydown', this._boundKeyHandler);
                    });
                }
            }

            handleKeydown(e) {
                if (this.items.length <= 1) return;
                // Don't intercept if user is typing in an input
                if (['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) return;

                if (e.key === 'ArrowRight') {
                    this.navigate(1);
                } else if (e.key === 'ArrowLeft') {
                    this.navigate(-1);
                }
            }

            navigate(direction) {
                let nextIndex = this.currentIndex + direction;
                if (nextIndex < 0) nextIndex = this.items.length - 1;
                if (nextIndex >= this.items.length) nextIndex = 0;

                this.currentIndex = nextIndex;
                this.updateActiveState();
                if (this.onSelect) this.onSelect(this.items[this.currentIndex], this.currentIndex);
            }

            setItems(items) {
                this.items = items; // [{ id, label, thumbSrc, data }]
                this.render();
            }

            setCurrentIndex(index) {
                this.currentIndex = index;
                this.updateActiveState();
            }

            render() {
                if (!this.footerContainer) return;
                this.footerContainer.innerHTML = '';
                this.footerContainer.className = 'gallery-footer';

                this.items.forEach((item, index) => {
                    const div = document.createElement('div');
                    div.className = 'gallery-item';
                    div.onclick = () => {
                        this.currentIndex = index;
                        this.updateActiveState();
                        if (this.onSelect) this.onSelect(item, index);
                    };

                    if (item.thumbSrc) {
                        const img = document.createElement('img');
                        img.src = item.thumbSrc;
                        img.className = 'gallery-thumb-img';
                        img.onload = () => { /* ensure loaded */ };
                        div.appendChild(img);
                    } else {
                        const placeholder = document.createElement('div');
                        placeholder.className = 'gallery-placeholder';
                        placeholder.innerText = item.label || (index + 1);
                        div.appendChild(placeholder);
                    }
                    // Tooltip title
                    div.title = item.label || `Item ${index + 1}`;

                    this.footerContainer.appendChild(div);
                });
            }

            updateActiveState() {
                if (!this.footerContainer) return;
                const children = this.footerContainer.children;
                for (let i = 0; i < children.length; i++) {
                    if (i === this.currentIndex) {
                        children[i].classList.add('active');
                        children[i].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                    } else {
                        children[i].classList.remove('active');
                    }
                }
            }
        }
    </script>
    {% block scripts %}{% endblock %}
</body>

</html>