@app.route('/api/dataset/upload', methods=['POST'])
def dataset_upload_api():
    """Programmatic dataset upload API"""
    if 'dataset_zip' not in request.files:
        return jsonify({'error': 'No dataset_zip file provided'}), 400
    
    file = request.files['dataset_zip']
    if file.filename == '':
        return jsonify({'error': 'No file selected'}), 400

    dataset_name = request.form.get('dataset_name', file.filename.replace('.zip', ''))
    filename = secure_filename(file.filename)
    
    temp_dir = os.path.join(app.config['UPLOAD_FOLDER'], 'temp_dataset_api_extract')
    os.makedirs(temp_dir, exist_ok=True)
    dataset_path = os.path.join(temp_dir, filename)
    dataset_path = os.path.join(temp_dir, filename)
    file.save(dataset_path)

    # Collision Check
    existing = Dataset.query.filter_by(name=dataset_name).first()
    if existing:
        if os.path.exists(temp_dir):
            shutil.rmtree(temp_dir)
        return jsonify({'error': f"Dataset '{dataset_name}' already exists."}), 409

    new_dataset_id = None
    try:
        new_dataset = Dataset(name=dataset_name)
        db.session.add(new_dataset)
        db.session.flush()
        new_dataset_id = new_dataset.id

        # Save original ZIP for API download
        dataset_folder_name = secure_filename(new_dataset.name)
        dataset_dir = os.path.join(app.config['UPLOAD_FOLDER'], 'datasets', dataset_folder_name)
        os.makedirs(dataset_dir, exist_ok=True)
        original_zip_name = f"{dataset_folder_name}.zip"
        original_zip_dest = os.path.join(dataset_dir, original_zip_name)
        shutil.copy2(dataset_path, original_zip_dest)

        with zipfile.ZipFile(dataset_path, 'r') as zip_ref:
            zip_ref.extractall(temp_dir)
            extracted_root = next((name.split('/')[0] for name in zip_ref.namelist() if '/' in name), ".") 
            dataset_content_path = os.path.join(temp_dir, extracted_root)

            # Git Info
            git_info_path = os.path.join(dataset_content_path, 'git.info')
            if os.path.exists(git_info_path):
                with open(git_info_path, 'r') as git_file:
                    git_data = json.load(git_file)
                    new_dataset.git_commit = git_data.get('commit', '')
                    new_dataset.git_branch = git_data.get('branch', '')
                    new_dataset.git_message = git_data.get('message', '')

            # Samples - fix: check existence before listing
            sample_names = set()
            for folder_name in ['hist', 'pick', 'config', 'wave_shape']:
                folder_path = os.path.join(dataset_content_path, folder_name)
                if os.path.exists(folder_path):
                    for fname in os.listdir(folder_path):
                        sample_names.add(os.path.splitext(fname)[0])
            
            for s_name in sample_names:
                sample = Sample(dataset_id=new_dataset.id, name=s_name)
                
                # Tags
                tags_file = os.path.join(dataset_content_path, 'tags', f'{s_name}.txt')
                if os.path.exists(tags_file):
                    with open(tags_file, 'r') as f:
                        sample.tags = f.read().strip()

                db.session.add(sample)
                db.session.flush()

                # Histogram
                hist_file = os.path.join(dataset_content_path, 'hist', f'{s_name}.npz')
                if os.path.exists(hist_file):
                    with np.load(hist_file) as data:
                        db.session.add(HistogramData(sample_id=sample.id, bins=json.dumps(data['bins'].tolist()), counts=json.dumps(data['counts'].tolist())))
                

                
                # Wave Shape
                wave_shape_file = os.path.join(dataset_content_path, 'wave_shape', f'{s_name}.txt')
                if os.path.exists(wave_shape_file):
                    with open(wave_shape_file, 'r') as f:
                        db.session.add(SignalShape(id=sample.id, shape_name=f.read().strip()))
                
                # Config
                config_file = os.path.join(dataset_content_path, 'config', f'{s_name}.json')
                if os.path.exists(config_file):
                    with open(config_file, 'r') as f:
                        db.session.add(ConfigData(id=sample.id, config_json=json.dumps(json.load(f))))
            
            # Custom Fields
            dataset_folder_name = secure_filename(new_dataset.name)
            dataset_images_dir = os.path.join(app.config['UPLOAD_FOLDER'], 'datasets', dataset_folder_name, 'images')
            os.makedirs(dataset_images_dir, exist_ok=True)
            
            known_folders = {'hist', 'config', 'wave_shape', 'tags', 'git.info'}
            images = detect_custom_fields(dataset_content_path, sample_names, known_folders, is_submission=False)
            
            for field_name, field_info in images.items():
                field_type = field_info['type']
                for s_name, value in field_info['data'].items():
                    sample = Sample.query.filter_by(dataset_id=new_dataset.id, name=s_name).first()
                    if sample:
                        if field_type == 'image':
                            field_folder = os.path.join(dataset_images_dir, field_name)
                            os.makedirs(field_folder, exist_ok=True)
                            filename = os.path.basename(value)
                            dest_path = os.path.join(field_folder, filename)
                            shutil.copy2(value, dest_path)
                            rel_path = os.path.relpath(dest_path, app.config['UPLOAD_FOLDER'])
                            custom_field = CustomField(name=field_name, field_type='image', value_text=rel_path, sample_id=sample.id)
                        else:
                            custom_field = CustomField(name=field_name, field_type='scalar', value_float=value, sample_id=sample.id)
                        db.session.add(custom_field)
        
        db.session.commit()
    except Exception as e:
        db.session.rollback()
        return jsonify({'error': str(e)}), 500
    finally:
        if os.path.exists(temp_dir):
            shutil.rmtree(temp_dir)

    return jsonify({'success': True, 'id': new_dataset_id, 'name': dataset_name})

