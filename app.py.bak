@app.route('/visualize/<string:vis_type>/<int:sample_id>')
def visualize_sample_image(vis_type, sample_id):
    sample = Sample.query.get_or_404(sample_id)
    sub_id = request.args.get('submission_id', type=int)
    
    bins, counts, peak_val = [], [], None
    title = f"{sample.name} - {vis_type}"
    
    if sub_id:
        sub = Submission.query.get(sub_id)
        if sub:
            sub_folder = os.path.join(app.config['UPLOAD_FOLDER'], 'submissions', str(sub.id))
            hist_file = None
            if os.path.exists(sub_folder):
                for fname in os.listdir(sub_folder):
                    if fname.startswith('hist_') or fname == 'raw_histogram':
                        cand = os.path.join(sub_folder, fname, f'{sample.name}.npz')
                        if os.path.exists(cand):
                            hist_file = cand
                            break
            
            # Try to load peak from custom fields - we don't know the exact metric name so we might have to skip or lookup by common names
            # For visualization overlay, we can check for common names like 'metric_peak', 'peak'
            for peak_name in ['metric_peak', 'peak']:
               peak_file = os.path.join(app.config['UPLOAD_FOLDER'], 'submissions', str(sub.id), peak_name, f'{sample.name}.txt')
               if os.path.exists(peak_file):
                   with open(peak_file) as f: peak_val = float(f.read())
                   break

            title = f"{sub.name}: {title}"
    else:
        if sample.histogram_data:
            bins = np.array(json.loads(sample.histogram_data.bins))
            counts = np.array(json.loads(sample.histogram_data.counts))
        for cf in sample.custom_fields:
            if cf.name == 'pick' and cf.field_type == 'scalar':
                peak_val = cf.value_float
                break

    if len(bins) == 0 or len(counts) == 0:
        return "No data", 404

    fig, ax = plt.subplots(figsize=(6, 4))
    
    if vis_type == 'trend_overlay':
        # Simple trend: 10-point moving average
        window = 10
        trend = np.convolve(counts, np.ones(window)/window, mode='same')
        
        # Anomaly detection: exceed trend + K * std
        diff = counts - trend
        threshold = 3 * np.std(diff)
        anomalies = counts > (trend + threshold)
        
        ax.step(bins, counts, label='Data', where='mid', color='#0d6efd', alpha=0.6)
        ax.plot(bins, trend, label='Trend', color='#dc3545', linewidth=2)
        
        # Highlight anomalies
        ax.scatter(bins[anomalies], counts[anomalies], color='red', s=20, label='Detections', zorder=5)
        ax.set_title(f"Trend & Anomalies: {sample.name}")


    ax.legend()
    ax_tight = fig.tight_layout()
    
    output = io.BytesIO()
    FigureCanvas(fig).print_png(output)
    plt.close(fig)
    return send_file(io.BytesIO(output.getvalue()), mimetype='image/png')

def get_vis_image_bytes(vis_type, sample, sub_id=None):
    """Helper to get visualization image bytes for inclusion in ZIP."""
    bins, counts, peak_val = [], [], None
    if sub_id:
        sub = Submission.query.get(sub_id)
        if sub:
            sub_folder = os.path.join(app.config['UPLOAD_FOLDER'], 'submissions', str(sub.id))
            hist_file = None
            if os.path.exists(sub_folder):
                for fname in os.listdir(sub_folder):
                    if fname.startswith('hist_') or fname == 'raw_histogram':
                        cand = os.path.join(sub_folder, fname, f'{sample.name}.npz')
                        if os.path.exists(cand):
                            hist_file = cand
                            break

            for peak_name in ['metric_peak', 'peak']:
               peak_file = os.path.join(app.config['UPLOAD_FOLDER'], 'submissions', str(sub.id), peak_name, f'{sample.name}.txt')
               if os.path.exists(peak_file):
                   with open(peak_file) as f: peak_val = float(f.read())
                   break
    else:
        if sample.histogram_data:
            bins = np.array(json.loads(sample.histogram_data.bins))
            counts = np.array(json.loads(sample.histogram_data.counts))
        for cf in sample.custom_fields:
            if cf.name == 'pick' and cf.field_type == 'scalar':
                peak_val = cf.value_float
                break

    if len(bins) == 0 or len(counts) == 0:
        return None

    fig, ax = plt.subplots(figsize=(6, 4))
    if vis_type == 'trend_overlay':
        window = 10
        trend = np.convolve(counts, np.ones(window)/window, mode='same')
        diff = counts - trend
        threshold = 3 * np.std(diff)
        anomalies = counts > (trend + threshold)
        ax.step(bins, counts, label='Data', where='mid', color='#0d6efd', alpha=0.6)
        ax.plot(bins, trend, label='Trend', color='#dc3545', linewidth=2)
        ax.scatter(bins[anomalies], counts[anomalies], color='red', s=20, label='Detections', zorder=5)
        ax.set_title(f"Trend: {sample.name}")
    elif vis_type == 'histogram_fit':
        shape_name = sample.signal_shape.shape_name if sample.signal_shape else 'gaussian'
        ax.step(bins, counts, label='Original', where='mid', color='gray', alpha=0.5)
        if peak_val is not None:
            try:
                p0 = [np.max(counts), peak_val, 1] if shape_name == 'gaussian' else [np.max(counts), peak_val-0.5, peak_val+0.5]
                func = gaussian if shape_name == 'gaussian' else square
                popt, _ = curve_fit(func, bins, counts, p0=p0)
                if shape_name == 'gaussian':
                    zoom_range = (popt[1] - 5*abs(popt[2]), popt[1] + 5*abs(popt[2]))
                else:
                    zoom_range = (popt[1] - 1, popt[2] + 1)
                fit_x = np.linspace(zoom_range[0], zoom_range[1], 200)
                ax.plot(fit_x, func(fit_x, *popt), color='red', linewidth=2, label='Fit')
                ax.set_xlim(zoom_range)
                ax.set_title(f"Fit: {sample.name}")
            except: ax.set_title("Fit Failed")
    
    ax.legend()
    fig.tight_layout()
    output = io.BytesIO()
    FigureCanvas(fig).print_png(output)
    plt.close(fig)
    return output.getvalue()

@app.route('/leaderboard/<int:leaderboard_id>/update_comparison_display_columns', methods=['POST'])
def update_comparison_display_columns(leaderboard_id):
    leaderboard = Leaderboard.query.get_or_404(leaderboard_id)
